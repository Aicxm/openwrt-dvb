name: N3160-OpenWrt-22.03 TBS-DVB Build
env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

on:
  push:
    branches: [ "master" ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04
    steps:
      - name: Download OpenWrt 22.03.5 x86_64 SDK
        run: |
          wget -O openwrt-sdk.tar.xz https://downloads.openwrt.org/releases/22.03.5/targets/x86/64/openwrt-sdk-22.03.5-x86-64_gcc-11.2.0_musl.Linux-x86_64.tar.xz
          tar -xf openwrt-sdk.tar.xz
          mv openwrt-sdk-* openwrt-sdk

      - name: Checkout DVB source code
        uses: actions/checkout@v4
        with:
          path: openwrt-sdk/package/openwrt-dvb

      - name: Init feeds & register package
        working-directory: openwrt-sdk
        run: |
          ./scripts/feeds update -a
          ./scripts/feeds install -a
          make defconfig

      - name: Clean & Compile & Build IPK
        working-directory: openwrt-sdk
        # 标准写法：进入包目录执行编译+打包
        run: make -C package/openwrt-dvb/v4l-dvb clean compile install V=s

      - name: Collect IPK packages
        uses: actions/upload-artifact@v4
        with:
          name: tbs-dvb-ipk
          path: openwrt-sdk/bin/packages/x86_64/base/*.ipk
          retention-days: 30
